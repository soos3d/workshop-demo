# Particle Network project credentials — get them free at https://dashboard.particle.network
PROJECT_ID=your_particle_project_id
PROJECT_CLIENT_KEY=your_client_key
PROJECT_APP_UUID=your_app_uuid

# Private key of a funded EOA (hold at least one Primary Asset on any supported chain).
# NEVER commit a real key. Use a throwaway demo wallet.
PRIVATE_KEY=0xyour_demo_wallet_private_key

# Optional: pin a specific Universal Account contract version.
# Leave unset to use the SDK default (UNIVERSAL_ACCOUNT_VERSION).
# UNIVERSAL_ACCOUNT_VERSION=
